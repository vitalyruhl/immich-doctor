# Identity / Project
TESTBED_PROJECT_NAME=immich-doctor-testbed

# Database
TESTBED_POSTGRES_IMAGE=ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0
TESTBED_DB_PORT=5432
TESTBED_DB_NAME=immich
TESTBED_DB_USER=postgres
TESTBED_DB_PASSWORD=postgres

TESTBED_DB_VOLUME=immich_dev_pgdata
TESTBED_DB_SNAPSHOT_VOLUME=immich_dev_pgdata_snapshot

# Dump bootstrap
TESTBED_INIT_MODE=FROM_DUMP

# Relative paths are resolved from dev/testbed/.
TESTBED_DUMP_PATH=
TESTBED_DUMP_FORMAT=auto
TESTBED_EXPORT_PATH=

# Docker / Image
TESTBED_IMMICH_DOCTOR_IMAGE=immich-doctor:local
TESTBED_DOCTOR_PORT=8000

# Storage Paths
TESTBED_STORAGE_SOURCE_MODE=mock
TESTBED_MOCK_STORAGE_PATH=../../data/mock/immich-library
TESTBED_REAL_STORAGE_PATH=
TESTBED_REAL_STORAGE_MODE=host-bind
TESTBED_REAL_STORAGE_SMB_SOURCE=
TESTBED_REAL_STORAGE_SMB_USERNAME=
TESTBED_REAL_STORAGE_SMB_PASSWORD=
TESTBED_REAL_STORAGE_SMB_VERS=3.0

# Runtime Paths
TESTBED_REPORTS_PATH=../../data/reports
TESTBED_MANIFESTS_PATH=../../data/manifests
TESTBED_QUARANTINE_PATH=../../data/quarantine
TESTBED_LOG_PATH=../../data/logs
TESTBED_TMP_PATH=../../data/tmp
TESTBED_CONFIG_PATH=../../config

# Local overrides and secrets belong in dev/testbed/.env.local.
# Example real-storage overrides:
# TESTBED_STORAGE_SOURCE_MODE=real
# TESTBED_REAL_STORAGE_PATH=R:/
# TESTBED_REAL_STORAGE_MODE=cifs
# TESTBED_REAL_STORAGE_SMB_SOURCE=//server/share/immich
# TESTBED_REAL_STORAGE_SMB_USERNAME=change-me
# TESTBED_REAL_STORAGE_SMB_PASSWORD=change-me
# TESTBED_REAL_STORAGE_SMB_VERS=3.0
