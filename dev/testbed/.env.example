# Dev testbed identity
TESTBED_PROJECT_NAME=immich-doctor-testbed

# PostgreSQL image compatible with current Immich guidance
TESTBED_POSTGRES_IMAGE=ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0

# Database connection values
TESTBED_DB_PORT=5432
TESTBED_DB_NAME=immich
TESTBED_DB_USER=postgres
TESTBED_DB_PASSWORD=postgres

# Named Docker volumes
TESTBED_DB_VOLUME=immich_dev_pgdata
TESTBED_DB_SNAPSHOT_VOLUME=immich_dev_pgdata_snapshot

# Initialization mode: FROM_DUMP or EMPTY
TESTBED_INIT_MODE=FROM_DUMP

# Host path to a pg_dump/pg_restore file, kept outside git
# Examples:
#   Windows: C:/temp/immich.dump
#   Linux:   /home/user/backups/immich.dump
# Relative paths are resolved from dev/testbed/
TESTBED_DUMP_PATH=

# Dump format: auto, custom, plain
TESTBED_DUMP_FORMAT=auto

# Optional export destination for export-db scripts.
# If left empty, exports default to dev/testbed/exports/immich-testbed-export.dump
# or .sql depending on the selected format.
TESTBED_EXPORT_PATH=

# Optional doctor image tag when you prefer pulling instead of local build
TESTBED_IMMICH_DOCTOR_IMAGE=ghcr.io/vitalyruhl/immich-doctor:MissingAssets

# Local runtime/UI verification
TESTBED_DOCTOR_PORT=8000

# Real-storage verification source path for read-only bind mounts.
# Keep this pointed at a synthetic path unless you intentionally want to inspect
# a real Immich storage tree from Docker Desktop / local Docker.
# Windows network-share source:
#   \\192.168.2.3\images\immich
# Docker Desktop bind-mount-friendly UNC form:
#   //192.168.2.3/images/immich
TESTBED_REAL_STORAGE_PATH=../../data/mock/immich-library

# Writable doctor paths must stay isolated from the read-only storage mount.
TESTBED_REPORTS_PATH=../../data/reports
TESTBED_MANIFESTS_PATH=../../data/manifests
TESTBED_QUARANTINE_PATH=../../data/quarantine
TESTBED_LOG_PATH=../../data/logs
TESTBED_TMP_PATH=../../data/tmp
TESTBED_CONFIG_PATH=../../config
