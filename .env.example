IMMICH_DOCTOR_ENVIRONMENT=development

# Application paths inside the container or local virtual environment.
IMMICH_DOCTOR_IMMICH_LIBRARY_ROOT=/mnt/immich/library
IMMICH_DOCTOR_IMMICH_UPLOADS_PATH=/mnt/immich/library/upload
IMMICH_DOCTOR_IMMICH_THUMBS_PATH=/mnt/immich/library/thumbs
IMMICH_DOCTOR_IMMICH_PROFILE_PATH=/mnt/immich/library/profile
IMMICH_DOCTOR_IMMICH_VIDEO_PATH=/mnt/immich/library/encoded-video

IMMICH_DOCTOR_BACKUP_TARGET_PATH=/mnt/backups/immich

IMMICH_DOCTOR_REPORTS_PATH=data/reports
IMMICH_DOCTOR_MANIFESTS_PATH=data/manifests
IMMICH_DOCTOR_QUARANTINE_PATH=data/quarantine
IMMICH_DOCTOR_LOGS_PATH=data/logs
IMMICH_DOCTOR_TMP_PATH=data/tmp

# Example:
# IMMICH_DOCTOR_POSTGRES_DSN=postgresql://immich:immich@postgres:5432/immich
IMMICH_DOCTOR_POSTGRES_DSN=
IMMICH_DOCTOR_POSTGRES_CONNECT_TIMEOUT_SECONDS=3

# Comma-separated values.
IMMICH_DOCTOR_REQUIRED_EXTERNAL_TOOLS=restic,pg_dump
IMMICH_DOCTOR_OPTIONAL_EXTERNAL_TOOLS=psql

# Host path hints for docker-compose.
HOST_IMMICH_LIBRARY_ROOT=/mnt/user/appdata/immich/library
HOST_BACKUP_TARGET_PATH=/mnt/user/backups/immich

