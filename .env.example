IMMICH_DOCTOR_ENVIRONMENT=development

# Preferred container-facing runtime variables.
IMMICH_STORAGE_PATH=/mnt/immich/storage
IMMICH_UPLOADS_PATH=/mnt/immich/storage/upload
IMMICH_THUMBS_PATH=/mnt/immich/storage/thumbs
IMMICH_PROFILE_PATH=/mnt/immich/storage/profile
IMMICH_VIDEO_PATH=/mnt/immich/storage/encoded-video

BACKUP_TARGET_PATH=/mnt/backups/immich
REPORTS_PATH=/data/reports
MANIFESTS_PATH=/data/manifests
QUARANTINE_PATH=/data/quarantine
LOG_PATH=/data/logs
TMP_PATH=/data/tmp
CONFIG_PATH=/config

# Database configuration. Use either DB_* values or IMMICH_DOCTOR_POSTGRES_DSN.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_CONNECT_TIMEOUT_SECONDS=3

# Optional DSN alternative.
IMMICH_DOCTOR_POSTGRES_DSN=

# Comma-separated values.
IMMICH_DOCTOR_REQUIRED_EXTERNAL_TOOLS=restic,pg_dump
IMMICH_DOCTOR_OPTIONAL_EXTERNAL_TOOLS=psql

# Runtime identity hints for Docker and Unraid.
PUID=1000
PGID=1000
UMASK=002
IMMICH_DOCTOR_PORT=8000

# Host mount placeholders for local and Unraid-style compose usage.
HOST_IMMICH_STORAGE_PATH=../data/mock/immich-library
HOST_BACKUP_TARGET_PATH=../data/mock/backups
HOST_REPORTS_PATH=../data/reports
HOST_MANIFESTS_PATH=../data/manifests
HOST_QUARANTINE_PATH=../data/quarantine
HOST_LOG_PATH=../data/logs
HOST_TMP_PATH=../data/tmp
HOST_CONFIG_PATH=../config

# Optional image override for docker-compose.unraid.yml.
IMMICH_DOCTOR_IMAGE=immich-doctor:unraid
